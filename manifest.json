{
  "manifest_version": 2,
  "name": "Gemini Message Navigator",
  "version": "1.0.3",
  "description": "DeepSeek 风格侧边导航栏 — 在 Gemini 对话中快速定位您的每一条消息。悬浮展开，点击跳转。",
  "author": "You",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "gemini-navigator@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  }
}
